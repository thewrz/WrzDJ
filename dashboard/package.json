{
  "name": "wrzdj-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "lint": "eslint app/ lib/",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "screenshots": "playwright test --config playwright.config.ts",
    "e2e": "playwright test --config playwright-e2e.config.ts",
    "types:export": "cd ../server && .venv/bin/python scripts/export_openapi.py",
    "types:generate": "openapi-typescript ../server/openapi.json -o lib/api-types.generated.ts"
  },
  "dependencies": {
    "@thumbmarkjs/thumbmarkjs": "^1.8.1",
    "next": "^16.2.4",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "simple-keyboard": "^3.8.136"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.5.0",
    "jsdom": "^29.1.0",
    "openapi-typescript": "^7.13.0",
    "typescript": "^6",
    "vitest": "^4.0.18"
  }
}
